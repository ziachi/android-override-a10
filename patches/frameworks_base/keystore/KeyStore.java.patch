Add this block:

                // Android Override: Replace attestation chain with imported keybox
                if (KeystoreIntegration.shouldInterceptAttestation()) {
                    try {
                        byte[] challenge = params.getBytes(
                            KeymasterDefs.KM_TAG_ATTESTATION_CHALLENGE, null);
                        if (challenge != null) {
                            // Get the attested key's public key
                            ExportResult exported = exportKey(
                                alias, KeymasterDefs.KM_KEY_FORMAT_X509,
                                null, null);
                            if (exported.resultCode == NO_ERROR) {
                                java.security.PublicKey pubKey = null;
                                try {
                                    java.security.KeyFactory kf =
                                        java.security.KeyFactory.getInstance("EC");
                                    pubKey = kf.generatePublic(
                                        new java.security.spec.X509EncodedKeySpec(
                                            exported.exportData));
                                } catch (Exception ec) {
                                    java.security.KeyFactory kf =
                                        java.security.KeyFactory.getInstance("RSA");
                                    pubKey = kf.generatePublic(
                                        new java.security.spec.X509EncodedKeySpec(
                                            exported.exportData));
                                }
                                java.util.List<byte[]> spoofed =
                                    KeystoreIntegration.generateSpoofedAttestationChain(
                                        pubKey, challenge, null, false);
                                if (spoofed != null && !spoofed.isEmpty()) {
                                    outChain.shallowCopyFrom(
                                        new KeymasterCertificateChain(spoofed));
                                    Log.d(TAG, "Override: attestation chain replaced ("
                                        + spoofed.size() + " certs)");
                                }
                            }
                        }
                    } catch (Exception e) {
                        Log.w(TAG, "Override: attestation hook error", e);
                    }
                }
                // End Override hook

== IMPORTANT NOTES ==
- ExportResult uses PUBLIC FIELDS: exported.resultCode, exported.exportData
  (NOT getters like getResultCode()/getExportData())
- KeymasterCertificateChain has constructor: new KeymasterCertificateChain(List<byte[]>)
- outChain.shallowCopyFrom() takes KeymasterCertificateChain, NOT List<byte[]>
- Tries EC key first, falls back to RSA (supports both key types)
