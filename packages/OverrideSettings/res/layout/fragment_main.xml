<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle_a10"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp" />

        <!-- Master Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/ic_override"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/master_switch"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Switch
                android:id="@+id/switch_master"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/text_fingerprint_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:textSize="12sp"
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Navigation Cards -->
        <LinearLayout
            android:id="@+id/card_fingerprint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔑  Fingerprint Spoofing" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/fingerprint_desc" android:textSize="13sp" android:textColor="#888" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_keybox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📦  Keybox Manager" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/keybox_desc_a10" android:textSize="13sp" android:textColor="#888" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_per_app"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📱  Per-App Profiles" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/per_app_desc" android:textSize="13sp" android:textColor="#888" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_profiles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💾  Profiles" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/profiles_desc" android:textSize="13sp" android:textColor="#888" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_integrity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅  SafetyNet Checker" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/integrity_desc_a10" android:textSize="13sp" android:textColor="#888" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_anti_detection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👻  Anti-Detection" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/anti_detection_desc" android:textSize="13sp" android:textColor="#888" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
