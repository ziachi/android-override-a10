<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Override"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#888888"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="20dp" />

        <!-- Active Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Override Active"
                android:textSize="16sp"
                android:textColor="#5FCFB4" />

            <TextView
                android:id="@+id/text_fingerprint_preview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#888888"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />

        <!-- Section: GMS Spoofing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GMS Spoofing"
            style="@style/SectionChip"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp" />

        <!-- Fingerprint Spoofing -->
        <LinearLayout
            android:id="@+id/card_fingerprint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Fingerprint spoofing"
                android:textColor="#EEEEEE" android:textSize="16sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Override Build.* fields for GMS identity"
                android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Keybox Manager -->
        <LinearLayout
            android:id="@+id/card_keybox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Keybox"
                android:textColor="#EEEEEE" android:textSize="16sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Import keybox XML for Keymaster attestation"
                android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" />

        <!-- About -->
        <LinearLayout
            android:id="@+id/card_about"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="About"
                android:textColor="#EEEEEE" android:textSize="16sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Version and developer info"
                android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
