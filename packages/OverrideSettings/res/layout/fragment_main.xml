<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Override"
            style="@style/SectionHeader"
            android:textSize="28sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#888"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="20dp" />

        <!-- Master Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Override enabled" style="@style/PrefTitle" />
                <TextView android:id="@+id/text_fingerprint_preview"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    style="@style/PrefSummary" android:fontFamily="monospace"
                    android:textSize="12sp" android:visibility="gone" />
            </LinearLayout>
            <Switch android:id="@+id/switch_master"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginTop="8dp" android:layout_marginBottom="8dp" />

        <!-- Spoofing -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Spoofing" style="@style/SectionChip"
            android:layout_marginStart="20dp" android:layout_marginTop="8dp" android:layout_marginBottom="12dp" />

        <LinearLayout android:id="@+id/card_fingerprint"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Fingerprint spoofing" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Override Build.* fields for device identity" style="@style/PrefSummary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/card_keybox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Keybox manager" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Import and manage attestation keybox XML" style="@style/PrefSummary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/card_per_app"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Per-app configuration" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Set different device identity per app" style="@style/PrefSummary" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginTop="8dp" android:layout_marginBottom="8dp" />

        <!-- Integrity -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Integrity" style="@style/SectionChip"
            android:layout_marginStart="20dp" android:layout_marginTop="8dp" android:layout_marginBottom="12dp" />

        <LinearLayout android:id="@+id/card_integrity"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Play Integrity check" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Predict basicIntegrity and ctsProfileMatch results" style="@style/PrefSummary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/card_anti_detection"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Anti-detection" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hide root, apps, and modification traces" style="@style/PrefSummary" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginTop="8dp" android:layout_marginBottom="8dp" />

        <!-- Misc -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Miscellaneous" style="@style/SectionChip"
            android:layout_marginStart="20dp" android:layout_marginTop="8dp" android:layout_marginBottom="12dp" />

        <LinearLayout android:id="@+id/card_profiles"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profiles" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Save and load override configurations" style="@style/PrefSummary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
