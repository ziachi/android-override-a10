<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Keybox Manager (Keymaster)" android:textSize="22sp" android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Enable switch -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Enable Keybox" android:textSize="16sp" />
            <Switch android:id="@+id/switch_keybox"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Status -->
        <TextView android:id="@+id/text_keybox_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="16sp" android:layout_marginBottom="8dp" />
        <TextView android:id="@+id/text_keybox_algorithm"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#888" android:visibility="gone" />
        <TextView android:id="@+id/text_keybox_slot"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#888" android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Import buttons -->
        <Button android:id="@+id/btn_import_keybox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="📁 Import Keybox (File Picker)"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_import_path"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="📝 Import from Path"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_manage_slots"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🔄 Manage Slots"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_health_check"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🔍 Health Check"
            android:layout_marginBottom="16dp" />

        <!-- Health result -->
        <TextView android:id="@+id/text_keybox_health"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:visibility="gone" />
    </LinearLayout>
</ScrollView>
