<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Keybox" style="@style/SectionHeader"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:layout_marginBottom="4dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Keymaster attestation spoofing"
            android:textSize="13sp" android:textColor="#888888"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:layout_marginBottom="20dp" />

        <!-- Enable switch -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Enable keybox spoofing" style="@style/PrefTitle" />
                <TextView android:id="@+id/text_keybox_status"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    style="@style/PrefSummary" />
            </LinearLayout>
            <Switch android:id="@+id/switch_keybox"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView android:id="@+id/text_keybox_algorithm"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="#888888"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="4dp" android:visibility="gone" />
        <TextView android:id="@+id/text_keybox_slot"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="#888888"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="2dp" android:visibility="gone" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#2A2A2A" android:layout_marginTop="8dp" android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Management" style="@style/SectionChip"
            android:layout_marginStart="20dp" android:layout_marginBottom="12dp" />

        <LinearLayout android:id="@+id/btn_import_keybox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Select keybox XML to import" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Import keybox XML for key attestation spoofing" style="@style/PrefSummary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/btn_import_path"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Import from path" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Import keybox XML from a specific file path" style="@style/PrefSummary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/btn_paste_keybox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Paste keybox XML" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Paste XML content directly (no file access needed)" style="@style/PrefSummary" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_manage_slots"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Manage slots" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Switch between imported keybox slots" style="@style/PrefSummary" />
        </LinearLayout>
        <LinearLayout android:id="@+id/btn_health_check"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:background="@drawable/bg_pref_item">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Health check" style="@style/PrefTitle" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Check if current keybox is valid or revoked" style="@style/PrefSummary" />
        </LinearLayout>
        <TextView android:id="@+id/text_keybox_health"
            android:textColor="#EEEEEE"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp"
            android:paddingStart="20dp" android:paddingEnd="20dp"
            android:paddingTop="12dp" android:visibility="gone" />
    </LinearLayout>
</ScrollView>
