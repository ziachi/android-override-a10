# SELinux policy for Android Override framework (Qassa ROM / Android 10)
#
# Override config lives at /data/system/override/ — this path
# inherits system_data_file label by default. system_server and
# system_app already have full access to system_data_file.
# No custom SELinux type needed.

# Suppress noisy denials from untrusted apps trying to probe
dontaudit untrusted_app system_data_file:dir search;
