# SELinux policy for Android Override framework (Qassa ROM / Android 10)
#
# Custom type for /data/system/override/ — allows cross-process access
# so GMS (priv_app) can read config for attestation hooks.
#
# IMPORTANT: appdomain neverallow blocks write/create on system_data_file.
# init.extras.rc MUST create /data/system/override/ at boot.
# App domains only get "search getattr" to navigate the parent path.

type override_data_file, file_type, data_file_type, core_data_file_type;

# type_transition: files/dirs created by system_app inside override_data_file
# dir inherit the override_data_file label (not system_app_data_file)
type_transition system_app override_data_file:file override_data_file;
type_transition system_app override_data_file:dir override_data_file;

# ==========================================================
# system_app (OverrideSettings, runs as android.uid.system)
# Full access to override_data_file dir/files
# ==========================================================
allow system_app override_data_file:dir { create open read write getattr setattr search add_name remove_name };
allow system_app override_data_file:file { create open read write getattr setattr unlink rename };
# Navigate /data/system/ to reach /data/system/override/
# NOTE: neverallow blocks write/add_name on system_data_file for appdomain
allow system_app system_data_file:dir { search getattr };

# ==========================================================
# system_server — read access (attestation hooks in framework)
# Already has full system_data_file access from platform policy
# ==========================================================
allow system_server override_data_file:dir { open read search getattr };
allow system_server override_data_file:file { open read getattr };

# ==========================================================
# priv_app (GMS) — read access for attestation hooks
# Needs search on system_data_file:dir to navigate to override/
# ==========================================================
allow priv_app override_data_file:dir { open read search getattr };
allow priv_app override_data_file:file { open read getattr };
allow priv_app system_data_file:dir { search getattr };

# ==========================================================
# platform_app — read access
# ==========================================================
allow platform_app override_data_file:dir { open read search getattr };
allow platform_app override_data_file:file { open read getattr };
allow platform_app system_data_file:dir { search getattr };

# ==========================================================
# init creates the directory at boot (init.extras.rc)
# This is the ONLY way dirs get created — apps can't due to neverallow
# ==========================================================
allow init override_data_file:dir { create setattr };
allow init override_data_file:file { getattr };

# Suppress noisy denials from untrusted apps
dontaudit untrusted_app override_data_file:dir search;
dontaudit untrusted_app_25 override_data_file:dir search;
dontaudit untrusted_app_27 override_data_file:dir search;
